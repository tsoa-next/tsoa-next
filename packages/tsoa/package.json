{
  "name": "tsoa-next",
  "version": "8.1.0",
  "description": "Build swagger-compliant REST APIs using TypeScript and Node",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "files": [
    "dist",
    "tsoa-next-logo-590.png"
  ],
  "bin": {
    "tsoa": "dist/cli-bin.js"
  },
  "scripts": {
    "build": "npm run tsc",
    "tsc": "tsc -b",
    "watch": "tsc -b -w"
  },
  "keywords": [
    "codegen",
    "express",
    "generation",
    "hapi.js",
    "koa",
    "node",
    "node.js",
    "openapi",
    "server",
    "swagger",
    "typescript"
  ],
  "author": "Vanna DiCatania <vanna@dicatania.me> (http://www.dicatania.me)",
  "license": "MIT",
  "dependencies": {
    "@tsoa-next/cli": "8.1.0",
    "@tsoa-next/runtime": "8.1.0"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "hapi-swagger": "^17.3.2",
    "rapidoc": "^9.3.8",
    "redoc": "^2.5.2",
    "swagger-ui-express": "^5.0.1",
    "swagger-ui-koa": "^0.0.1"
  },
  "peerDependenciesMeta": {
    "hapi-swagger": {
      "optional": true
    },
    "rapidoc": {
      "optional": true
    },
    "redoc": {
      "optional": true
    },
    "swagger-ui-express": {
      "optional": true
    },
    "swagger-ui-koa": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tsoa-next/tsoa-next.git",
    "directory": "packages/tsoa"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "engineStrict": true,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "require": "./dist/cli.js",
      "default": "./dist/cli.js"
    },
    "./package.json": "./package.json"
  },
  "homepage": "https://tsoa-next.dev",
  "typesVersions": {
    "*": {
      "cli": [
        "dist/cli.d.ts"
      ]
    }
  }
}
