    "@tsoa-next/runtime": "7.3.1"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tsoa-next/tsoa-next.git",
    "directory": "packages/tsoa"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
