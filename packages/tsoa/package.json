{
  "name": "tsoa-next",
  "description": "Build swagger-compliant REST APIs using TypeScript and Node",
  "version": "7.0.0",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "typescript",
    "openapi",
    "swagger",
    "server",
    "node",
    "node.js",
    "codegen",
    "generation",
    "express",
    "hapi.js",
    "koa"
  ],
  "scripts": {
    "build": "npm run tsc",
    "tsc": "tsc -b",
    "watch": "tsc -b -w"
  },
  "author": "Luke Autry <lukeautry@gmail.com> (http://www.lukeautry.com)",
  "license": "MIT",
  "dependencies": {
    "@tsoa/cli": "^7.0.0",
    "@tsoa/runtime": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VannaDii/tsoa-next.git"
  },
  "bin": {
    "tsoa": "dist/cli.js"
  },
  "engines": {
    "npm": ">=11.0.0",
    "node": ">=24.14.0"
  },
  "engineStrict": true,
  "publishConfig": {
    "access": "public"
  }
