{
  "name": "@tsoa-next/cli",
  "version": "7.3.4",
  "description": "Build swagger-compliant REST APIs using TypeScript and Node",
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "tsoa": "dist/cli.js"
  },
  "scripts": {
    "build": "npm run clean && npm run tsc && npm run copy-templates",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "copy-templates": "copyfiles -u 1 ./src/routeGeneration/templates/*.hbs ./dist",
    "tsc": "tsc -b",
    "watch": "tsc -b -w"
  },
  "keywords": [
    "codegen",
    "express",
    "generation",
    "hapi.js",
    "koa",
    "node",
    "node.js",
    "openapi",
    "server",
    "swagger",
    "typescript"
  ],
  "author": "Vanna DiCatania <vanna@dicatania.me> (http://www.dicatania.me)",
  "license": "MIT",
  "dependencies": {
    "@tsoa-next/runtime": "7.3.4",
    "@types/multer": "^2.1.0",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "handlebars": "^4.7.9",
    "minimatch": "^10.2.4",
    "ts-deepmerge": "^7.0.3",
    "typescript": "^5.9.3",
    "validator": "^13.15.26",
    "yaml": "^2.8.3",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/minimatch": "^6.0.0",
    "@types/node": "24.12.0",
    "@types/validator": "^13.15.10",
    "@types/yargs": "^17.0.35",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.1.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tsoa-next/tsoa-next.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "engineStrict": true,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://tsoa-next.dev"
}
