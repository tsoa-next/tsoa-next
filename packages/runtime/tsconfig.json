{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "module": "commonjs",
    "types": [
      "node"
    ],
    "composite": true,
    "target": "esnext",
    "lib": [
      "esnext"
    ],
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "declaration": true,
    "noUnusedLocals": true,
    "newLine": "LF",
    "noUnusedParameters": false,
    "emitDecoratorMetadata": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "strict": true
  }
}
