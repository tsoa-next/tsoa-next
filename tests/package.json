{
  "name": "tsoa-tests",
  "version": "7.0.0",
  "private": true,
  "description": "Build swagger-compliant REST APIs using TypeScript and Node",
  "scripts": {
    "clean": "rimraf --glob dist fixtures/*/routes.ts fixtures/*/customRoutes.ts fixtures/*/custom-route-generator/routes/*",
    "prepare-test": "cross-env NODE_ENV=tsoa_test ts-node --require=tsconfig-paths/register ./prepare.ts",
    "pretest": "npm run clean && npm run prepare-test && npm run typecheck",
    "test": "cross-env NODE_ENV=tsoa_test mocha \"**/*.spec.ts\" --timeout 40000",
    "test:ci": "cross-env NODE_ENV=tsoa_test mocha \"**/*.spec.ts\" --parallel --timeout 40000",
    "test:long": "npm run test:ci",
    "typecheck": "tsc"
  },
  "keywords": [
    "codegen",
    "express",
    "generation",
    "hapi.js",
    "koa",
    "node",
    "node.js",
    "openapi",
    "server",
    "swagger",
    "typescript"
  ],
  "author": "Vanna DiCatania <vanna@dicatania.me> (https://www.dicatania.me)",
  "license": "MIT",
  "devDependencies": {
    "@hapi/hapi": "^21.4.9",
    "@koa/multer": "^4.0.0",
    "@koa/router": "^15.7.0",
    "@types/body-parser": "^1.19.6",
    "@types/chai": "^5.2.3",
    "@types/express": "5.0.6",
    "@types/koa": "^3.0.3",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa__router": "^12.0.5",
    "@types/method-override": "3.0.0",
    "@types/mocha": "^10.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "22.20.0",
    "@types/promise.any": "^2.0.3",
    "@types/sinon": "^22.0.0",
    "@types/supertest": "^7.2.1",
    "aws-cdk-lib": "^2.261.0",
    "body-parser": "^2.3.0",
    "chai": "^6.2.2",
    "chalk": "^5.6.2",
    "constructs": "^10.7.1",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "fp-ts": "^2.16.11",
    "inversify": "^6.2.2",
    "inversify-binding-decorators": "^4.0.0",
    "io-ts": "^2.2.22",
    "io-ts-types": "^0.5.19",
    "joi": "^18.2.3",
    "koa": "^3.2.1",
    "koa-bodyparser": "^4.4.1",
    "method-override": "^3.0.0",
    "mocha": "12.0.0-rc.2",
    "multer": "^2.2.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "sinon": "^22.1.0",
    "superstruct": "^2.0.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "yup": "^1.7.1",
    "zod": "^4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tsoa-next/tsoa-next.git"
  },
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=12.0.0"
  },
  "engineStrict": true
}
