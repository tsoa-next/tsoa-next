{
  "name": "tsoa-tests",
  "version": "7.0.0",
  "private": true,
  "description": "Build swagger-compliant REST APIs using TypeScript and Node",
  "scripts": {
    "clean": "rimraf --glob dist fixtures/*/routes.ts fixtures/*/customRoutes.ts fixtures/*/custom-route-generator/routes/*",
    "prepare-test": "cross-env NODE_ENV=tsoa_test ts-node --require=tsconfig-paths/register ./prepare.ts",
    "pretest": "npm run clean && npm run prepare-test && npm run typecheck",
    "test": "cross-env NODE_ENV=tsoa_test mocha \"**/*.spec.ts\"",
    "test:ci": "cross-env NODE_ENV=tsoa_test mocha \"**/*.spec.ts\" --parallel --timeout 20000",
    "test:long": "npm run test:ci",
    "typecheck": "tsc"
  },
  "keywords": [
    "codegen",
    "express",
    "generation",
    "hapi.js",
    "koa",
    "node",
    "node.js",
    "openapi",
    "server",
    "swagger",
    "typescript"
  ],
  "author": "Vanna DiCatania <vanna@dicatania.me> (https://www.dicatania.me)",
  "license": "MIT",
  "devDependencies": {
    "@hapi/hapi": "^21.4.8",
    "@koa/multer": "^3.0.2",
    "@koa/router": "^13.1.0",
    "@types/body-parser": "^1.19.6",
    "@types/chai": "^4.3.19",
    "@types/express": "5.0.3",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa__router": "^12.0.5",
    "@types/method-override": "3.0.0",
    "@types/mocha": "^10.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "24.12.0",
    "@types/promise.any": "^2.0.3",
    "@types/sinon": "^17.0.3",
    "@types/supertest": "^6.0.2",
    "aws-cdk-lib": "^2.248.0",
    "body-parser": "^1.20.3",
    "chai": "^4.3.10",
    "chalk": "^4.1.2",
    "constructs": "^10.4.2",
    "cross-env": "^7.0.3",
    "express": "^5.2.1",
    "fp-ts": "^2.16.11",
    "inversify": "^6.1.6",
    "inversify-binding-decorators": "^4.0.0",
    "io-ts": "^2.2.21",
    "io-ts-types": "^0.5.19",
    "joi": "^17.13.3",
    "koa": "^3.1.2",
    "koa-bodyparser": "^4.4.0",
    "method-override": "^3.0.0",
    "mocha": "^11.7.5",
    "multer": "^2.0.2",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "sinon": "^21.1.2",
    "superstruct": "^2.0.2",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "yup": "^1.7.1",
    "zod": "^4.1.11"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tsoa-next/tsoa-next.git"
  },
  "engines": {
    "node": ">=24.14.0",
    "npm": ">=11.0.0"
  },
  "engineStrict": true
}
