{
  "name": "tsoa-monorepo",
  "description": "Build swagger-compliant REST APIs using TypeScript and Node",
  "private": true,
  "keywords": [
    "typescript",
    "openapi",
    "swagger",
    "server",
    "node",
    "node.js",
    "codegen",
    "generation",
    "express",
    "hapi.js",
    "koa"
  ],
  "author": "Luke Autry <lukeautry@gmail.com> (http://www.lukeautry.com)",
  "license": "MIT",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "npm run lint:fix"
    ]
  },
  "scripts": {
    "build": "turbo run build --output-logs=full",
    "clean": "turbo run clean --output-logs=full",
    "prepare": "npm run build",
    "preversion": "npm run test",
    "test": "turbo run test --concurrency=1 --output-logs=full",
    "lint": "eslint . --ext .ts",
    "lint:fix": "npm run lint -- --fix",
    "watch": "turbo run watch --parallel --output-logs=full",
    "turbo": "turbo",
    "typedocs": "typedoc --options ./typedoc.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^4.3.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.8.20",
    "ts-node": "^10.9.2",
    "typedoc": "^0.26.7"
  },
  "overrides": {
    "typescript": "^5.2.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VannaDii/tsoa-next.git"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=18.0.0"
  },
  "engineStrict": true,
  "workspaces": [
    "packages/*",
    "tests",
    "tests/esm"
  ],
  "packageManager": "npm@10.9.2"
}
