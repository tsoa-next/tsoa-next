{
  "name": "tsoa-monorepo",
  "private": true,
  "description": "Build swagger-compliant REST APIs using TypeScript and Node",
  "scripts": {
    "build": "turbo run build --output-logs=full",
    "changeset": "changeset",
    "check:pre-commit": "npm run build && npm run lint",
    "check:pre-push": "node ./scripts/check-pre-push.cjs",
    "check:standard": "npm run build && npm run lint && npm run test",
    "clean": "turbo run clean --output-logs=full",
    "coverage": "node ./scripts/run-coverage.cjs",
    "docs:api": "typedoc --options ./typedoc.json && node ./scripts/postprocess-reference-docs.cjs",
    "docs:build": "node --max-old-space-size=8192 ./node_modules/vitepress/dist/node/cli.js build site/guide-docs",
    "docs:dev": "vitepress dev site/guide-docs",
    "docs:i18n": "node ./scripts/sync-doc-locales.mjs",
    "docs:preview": "vitepress preview site/guide-docs",
    "fix:deps": "syncpack fix && syncpack format",
    "lint": "npm run lint:deps && eslint .",
    "lint:deps": "syncpack lint && syncpack format --check",
    "lint:fix": "npm run lint -- --fix",
    "predocs:build": "npm run docs:api",
    "predocs:dev": "npm run docs:api",
    "predocs:preview": "npm run docs:api",
    "prepare": "husky && npm run build",
    "prepare-dev-publish": "node ./scripts/prepare-dev-publish.cjs",
    "prettier": "node --experimental-strip-types ./node_modules/prettier/bin/prettier.cjs",
    "preversion": "npm run test",
    "release": "npm run build && changeset publish",
    "sync:readmes": "node ./scripts/sync-readmes.cjs",
    "sync:readmes:check": "node ./scripts/sync-readmes.cjs --check",
    "syncpack": "syncpack",
    "test": "turbo run test --output-logs=full",
    "turbo": "turbo",
    "typedocs": "npm run docs:api",
    "version-packages": "changeset version && npm run fix:deps && npm install --ignore-scripts",
    "watch": "turbo run watch --parallel --output-logs=full"
  },
  "keywords": [
    "codegen",
    "express",
    "generation",
    "hapi.js",
    "koa",
    "node",
    "node.js",
    "openapi",
    "server",
    "swagger",
    "typescript"
  ],
  "author": "Vanna DiCatania <vanna@dicatania.me> (http://www.dicatania.me)",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@nolebase/vitepress-plugin-git-changelog": "^2.18.2",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "c8": "^12.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "inversify": "^6.2.2",
    "jiti": "^2.7.0",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.6",
    "sass": "^1.101.3",
    "syncpack": "^15.3.2",
    "ts-node": "^10.9.2",
    "turbo": "^2.10.5",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vitepress-plugin-llms": "^1.13.3",
    "vue": "^3.5.40"
  },
  "overrides": {
    "vite": "6.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tsoa-next/tsoa-next.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "engineStrict": true,
  "workspaces": [
    "packages/*",
    "tests",
    "tests/esm"
  ],
  "packageManager": "npm@12.0.1",
  "homepage": "https://tsoa-next.dev",
  "lint-staged": {
    "*.{js,ts}": [
      "npm run prettier -- --write",
      "npm run lint:fix"
    ]
  }
}
