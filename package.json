{
  "name": "tsoa-monorepo",
  "private": true,
  "description": "Build swagger-compliant REST APIs using TypeScript and Node",
  "scripts": {
    "build": "turbo run build --output-logs=full",
    "changeset": "changeset",
    "check:pre-commit": "npm run build && npm run lint",
    "check:pre-push": "npm run test",
    "check:standard": "npm run build && npm run lint && npm run test",
    "clean": "turbo run clean --output-logs=full",
    "coverage": "rimraf coverage && npm --prefix tests run pretest && c8 npm --prefix tests run test:coverage",
    "docs:build": "vitepress build site/guide-docs",
    "docs:dev": "vitepress dev site/guide-docs",
    "docs:preview": "vitepress preview site/guide-docs",
    "fix:deps": "syncpack fix && syncpack format",
    "lint": "npm run lint:deps && eslint .",
    "lint:deps": "syncpack lint && syncpack format --check",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky && npm run build",
    "prettier": "node --experimental-strip-types ./node_modules/prettier/bin/prettier.cjs",
    "preversion": "npm run test",
    "release": "npm run build && changeset publish",
    "syncpack": "syncpack",
    "test": "turbo run test --concurrency=1 --output-logs=full",
    "turbo": "turbo",
    "typedocs": "typedoc --options ./typedoc.json",
    "version-packages": "changeset version && npm run fix:deps && npm install --ignore-scripts",
    "watch": "turbo run watch --parallel --output-logs=full"
  },
  "keywords": [
    "codegen",
    "express",
    "generation",
    "hapi.js",
    "koa",
    "node",
    "node.js",
    "openapi",
    "server",
    "swagger",
    "typescript"
  ],
  "author": "Vanna DiCatania <vanna@dicatania.me> (http://www.dicatania.me)",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "c8": "^10.1.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "syncpack": "^14.2.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.8.20",
    "typedoc": "^0.28.17",
    "vitepress": "^1.6.4",
    "vue": "^3.5.30"
  },
  "overrides": {
    "@tsoa-next/runtime": {
      "@types/koa": "2.15.0"
    },
    "@types/koa": "2.15.0",
    "@types/node": "24.12.0",
    "chalk": "4.1.2",
    "esbuild": "0.25.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VannaDii/tsoa-next.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "engineStrict": true,
  "workspaces": [
    "packages/*",
    "tests",
    "tests/esm"
  ],
  "packageManager": "npm@11.9.0",
  "homepage": "https://tsoa-next.dev",
  "lint-staged": {
    "*.{js,ts}": [
      "npm run prettier -- --write",
      "npm run lint:fix"
    ]
  }
}
