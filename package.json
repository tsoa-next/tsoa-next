{
  "name": "tsoa-monorepo",
  "description": "Build swagger-compliant REST APIs using TypeScript and Node",
  "private": true,
  "keywords": [
    "typescript",
    "openapi",
    "swagger",
    "server",
    "node",
    "node.js",
    "codegen",
    "generation",
    "express",
    "hapi.js",
    "koa"
  ],
  "author": "Vanna DiCatania <vanna@dicatania.me> (http://www.dicatania.me)",
  "license": "MIT",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "npm run prettier -- --write",
      "npm run lint:fix"
    ]
  },
  "scripts": {
    "build": "turbo run build --output-logs=full",
    "clean": "turbo run clean --output-logs=full",
    "prettier": "node --experimental-strip-types ./node_modules/prettier/bin/prettier.cjs",
    "prepare": "npm run build",
    "preversion": "npm run test",
    "test": "turbo run test --concurrency=1 --output-logs=full",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "watch": "turbo run watch --parallel --output-logs=full",
    "turbo": "turbo",
    "typedocs": "typedoc --options ./typedoc.json"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "syncpack": "^14.2.0",
    "ts-node": "^10.9.2",
    "turbo": "^2.8.20",
    "typedoc": "^0.28.17"
  },
  "overrides": {
    "chalk": "4.1.2",
    "@types/koa": "2.15.0",
    "@tsoa/runtime": {
      "@types/koa": "2.15.0"
    },
    "@types/node": "24.12.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VannaDii/tsoa-next.git"
  },
  "engines": {
    "npm": ">=11.0.0",
    "node": ">=24.14.0"
  },
  "engineStrict": true,
  "workspaces": [
    "packages/*",
    "tests",
    "tests/esm"
  ],
  "packageManager": "npm@11.9.0"
}
